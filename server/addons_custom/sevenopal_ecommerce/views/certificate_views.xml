<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="sevenopal_certificate_list_view" model="ir.ui.view">
        <field name="name">sevenopal.certificate.list</field>
        <field name="model">sevenopal.certificate</field>
        <field name="arch" type="xml">
            <list string="Certificates">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="cert_type"/>
                <field name="charge"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="sevenopal_certificate_form_view" model="ir.ui.view">
        <field name="name">sevenopal.certificate.form</field>
        <field name="model">sevenopal.certificate</field>
        <field name="arch" type="xml">
            <form string="Certificate">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="cert_type"/>
                        <field name="charge" invisible="cert_type == 'free'"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sevenopal_certificate_action" model="ir.actions.act_window">
        <field name="name">Certificate Options</field>
        <field name="res_model">sevenopal.certificate</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
