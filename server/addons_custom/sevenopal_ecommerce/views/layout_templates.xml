                </svg>
                <span class="so_whatsapp_label">Chat Now</span>
            </a>
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Cart page — dark theme wrapper
    ══════════════════════════════════════════════════════════ -->
    <template
        id="sevenopal_cart_page"
        inherit_id="website_sale.cart"
        name="SevenOpal – Cart Dark Theme"
    >
        <xpath expr="//div[@id='shop_cart']" position="attributes">
            <attribute name="class" add="so_cart_page"/>
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Checkout — dark theme wrapper
    ══════════════════════════════════════════════════════════ -->
    <template
        id="sevenopal_checkout_page"
        inherit_id="website_sale.checkout"
        name="SevenOpal – Checkout Dark Theme"
    >
        <xpath expr="//div[@id='shop_checkout']" position="before">
            <div class="so_checkout_header py-3 mb-3" style="border-bottom:1px solid #2c2f38;">
                <div class="container">
                    <div class="d-flex align-items-center gap-3">
                        <i class="fa fa-lock" style="color:#c0392b; font-size:1.2rem;"/>
                        <span class="small fw-bold" style="color:#e8e8e8;">Secure Checkout – Your information is encrypted &amp; safe</span>
                    </div>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Product detail — tabbed spec section
         Injects "Product Details | Description | Reviews" tab nav
         above the accordion items
    ══════════════════════════════════════════════════════════ -->
    <template
        id="sevenopal_product_detail_tabs"
        inherit_id="website_sale.product"
        name="SevenOpal – Product Detail Tab Nav"
    >
        <xpath expr="//div[@id='product_details']" position="before">
            <div class="so_detail_tabs_nav container">
                <div class="so_detail_tab_strip d-flex gap-0">
                    <button class="so_detail_tab_btn so_detail_tab_active"
                            onclick="soTabSwitch(this,'so_tab_specs')">
                        Product Details
                    </button>
                    <button class="so_detail_tab_btn"
                            onclick="soTabSwitch(this,'so_tab_desc')">
                        Description
                    </button>
                    <button class="so_detail_tab_btn"
                            onclick="soTabSwitch(this,'so_tab_reviews')">
                        Reviews
                    </button>
                </div>
            </div>
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Product detail — CTA button bar improvements
         Adds an extra "Buy Now" button beside "Add to Cart"
    ══════════════════════════════════════════════════════════ -->
    <template
        id="sevenopal_product_cta_bar"
        inherit_id="website_sale.product"
        name="SevenOpal – Product CTA Buttons"
    >
        <xpath expr="//div[hasclass('o_wsale_product_details_content_section_cta')]" position="attributes">
            <attribute name="class" add="so_cta_section"/>
        </xpath>
    </template>

    <!-- ══════════════════════════════════════════════════════
         Shop — category header title
    ══════════════════════════════════════════════════════════ -->
    <template
        id="sevenopal_shop_header"
        inherit_id="website_sale.products"
        name="SevenOpal – Shop Header"
    >
        <xpath expr="//div[hasclass('o_wsale_products_page')]" position="attributes">
            <attribute name="class" add="so_shop_page"/>
        </xpath>
    </template>

</odoo>
